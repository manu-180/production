# Build stage: install dependencies
FROM node:20-alpine AS deps

# Install pnpm
RUN npm install -g pnpm@10.33.0

WORKDIR /app

# Copy workspace configuration files
COPY pnpm-workspace.yaml .
COPY pnpm-lock.yaml .
COPY package.json .

# Copy all package.json files for workspace packages
COPY apps/web/package.json apps/web/
COPY apps/worker/package.json apps/worker/
COPY packages/core/package.json packages/core/
COPY packages/db/package.json packages/db/

# Install dependencies with frozen lockfile for reproducibility
RUN pnpm install --frozen-lockfile


# Build stage: compile application
FROM node:20-alpine AS builder

# Install pnpm
RUN npm install -g pnpm@10.33.0

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

WORKDIR /app

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy workspace configuration
COPY pnpm-workspace.yaml .
COPY pnpm-lock.yaml .
COPY package.json .

# Copy source code for all packages
COPY apps/web ./apps/web
COPY apps/worker ./apps/worker
COPY packages/core ./packages/core
COPY packages/db ./packages/db
COPY tsconfig.base.json .
COPY turbo.json .

# Build using turbo (which includes web build with Next.js standalone output)
RUN pnpm build

# Verify standalone output exists
RUN test -d apps/web/.next/standalone || (echo "Next.js standalone output not found" && exit 1)


# Runtime stage: production image
FROM node:20-alpine AS runner

WORKDIR /app

# Create non-root user for security
RUN addgroup -g 1001 -S nextjs && \
    adduser -S nextjs -u 1001

# Copy the built application from builder
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/public ./apps/web/public

# Switch to non-root user
USER nextjs

# Expose port
EXPOSE 3000

# Environment variables
ENV PORT=3000 \
    HOSTNAME=0.0.0.0 \
    NODE_ENV=production

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000/api/system/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})"

# Start Next.js server
CMD ["node", "apps/web/server.js"]
