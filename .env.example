# Supabase (web — Next.js public vars)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (worker — reads SUPABASE_URL directly, not the NEXT_PUBLIC_ prefixed var)
SUPABASE_URL=

# Conductor
CONDUCTOR_ENCRYPTION_KEY=        # 32 bytes hex para encriptar OAuth tokens
CONDUCTOR_DEFAULT_MODEL=claude-sonnet-4-7

# Worker
WORKER_CONCURRENCY=1

# Notifications (email via Resend)
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=conductor@notifications.app

# Logging
LOG_LEVEL=info

# App
NODE_ENV=development
